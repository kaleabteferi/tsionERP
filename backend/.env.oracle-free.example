# Oracle Cloud Always Free VM + Docker Compose
# Copy to backend/.env on the server and replace placeholder values.

DB_NAME=tsion_erp
DB_USER=postgres
DB_PASSWORD=change_me_to_a_strong_password

PORT=3001
NODE_ENV=production
FRONTEND_URL=http://YOUR_ORACLE_PUBLIC_IP:3001

# Oracle VM works well with local persistent disk.
FILE_STORAGE_DRIVER=local
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

COMPANY_NAME=Tsion Parboiled Brown Rice
COMPANY_PHONE=+251 94 413 5444
COMPANY_ADDRESS=Addis Ababa, Ethiopia
COMPANY_TIN=your_tin_here
COMPANY_TAGLINE=100% Natural · Healthy · Gluten Free · Made in Ethiopia
