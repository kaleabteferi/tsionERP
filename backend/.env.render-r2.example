# Render web service + Render Postgres + Cloudflare R2
# Copy values into the Render dashboard env var panel.

NODE_ENV=production
PORT=3001
FRONTEND_URL=https://your-app.onrender.com

DB_HOST=<from-render-postgres>
DB_PORT=<from-render-postgres>
DB_NAME=<from-render-postgres>
DB_USER=<from-render-postgres>
DB_PASSWORD=<from-render-postgres>

FILE_STORAGE_DRIVER=s3
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=tsion-erp-files
S3_ACCESS_KEY_ID=<cloudflare-r2-access-key>
S3_SECRET_ACCESS_KEY=<cloudflare-r2-secret-key>
S3_FORCE_PATH_STYLE=false

GOOGLE_MAPS_API_KEY=<your-google-maps-key>

COMPANY_NAME=Tsion Parboiled Brown Rice
COMPANY_PHONE=+251 94 413 5444
COMPANY_ADDRESS=Addis Ababa, Ethiopia
COMPANY_TIN=<your-company-tin>
COMPANY_TAGLINE=100% Natural · Healthy · Gluten Free · Made in Ethiopia
