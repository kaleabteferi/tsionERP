# Railway app service + Railway Postgres + AWS S3
# Copy values into the Railway service variables panel.

NODE_ENV=production
PORT=3001
FRONTEND_URL=https://your-app.up.railway.app

DB_HOST=<from-railway-postgres>
DB_PORT=<from-railway-postgres>
DB_NAME=<from-railway-postgres>
DB_USER=<from-railway-postgres>
DB_PASSWORD=<from-railway-postgres>

FILE_STORAGE_DRIVER=s3
S3_ENDPOINT=
S3_REGION=eu-central-1
S3_BUCKET=tsion-erp-files
S3_ACCESS_KEY_ID=<aws-access-key-id>
S3_SECRET_ACCESS_KEY=<aws-secret-access-key>
S3_FORCE_PATH_STYLE=false

GOOGLE_MAPS_API_KEY=<your-google-maps-key>

COMPANY_NAME=Tsion Parboiled Brown Rice
COMPANY_PHONE=+251 94 413 5444
COMPANY_ADDRESS=Addis Ababa, Ethiopia
COMPANY_TIN=<your-company-tin>
COMPANY_TAGLINE=100% Natural · Healthy · Gluten Free · Made in Ethiopia
