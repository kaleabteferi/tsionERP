# Tsion ERP — Environment Configuration
# Copy this file to .env and fill in your values

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tsion_erp
DB_USER=postgres
DB_PASSWORD=change_me

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3001

# File Storage
# local = store files on server disk
# s3    = store files in S3 / Cloudflare R2 / MinIO / Backblaze B2 (S3-compatible)
FILE_STORAGE_DRIVER=local
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# Google Maps API Key
# Get yours at: https://console.cloud.google.com/
# Enable: Maps JavaScript API + Places API + Geocoding API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Company Info (used in PDF generation)
COMPANY_NAME=Tsion Parboiled Brown Rice
COMPANY_PHONE=+251 94 413 5444
COMPANY_ADDRESS=Addis Ababa, Ethiopia
COMPANY_TIN=your_tin_here
COMPANY_TAGLINE=100% Natural · Healthy · Gluten Free · Made in Ethiopia
